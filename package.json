{
  "name": "telegram-client",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@types/bun": "latest",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "start": "bun run apps/cli/src/index.ts",
    "web": "bun run apps/web/src/server.ts",
    "mobile": "cd apps/mobile && expo start",
    "test": "bun test",
    "test:mutation": "stryker run",
    "typecheck": "tsc --noEmit",
    "lint": "biome ci",
    "format": "biome check --write",
    "build": "bun build apps/cli/src/index.ts --compile --outfile dist/tg-client"
  }
}
