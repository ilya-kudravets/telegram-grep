{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "command",
  "commandRunner": { "command": "bun test" },
  "checkers": ["typescript"],
  "plugins": ["@stryker-mutator/typescript-checker"],
  "tsconfigFile": "tsconfig.json",
  "coverageAnalysis": "off",
  "ignorePatterns": ["spike-rn", "apps/mobile", "apps/cli/web", "data", "reports", "dist"],
  "mutate": [
    "apps/cli/src/api.ts",
    "apps/cli/src/adapters/bun-sqlite.ts",
    "apps/cli/src/adapters/patterns-fs.ts",
    "packages/core/src/cache.ts",
    "packages/core/src/deleter.ts",
    "packages/core/src/search.ts",
    "packages/core/src/sync.ts"
  ],
  "reporters": ["html", "json", "clear-text", "progress"],
  "jsonReporter": { "fileName": "reports/mutation/mutation.json" },
  "tempDirName": ".stryker-tmp",
  "thresholds": { "high": 80, "low": 60, "break": 0 }
}
